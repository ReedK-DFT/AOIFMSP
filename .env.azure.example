# AOIFMSP Azure runtime configuration
# Copy the values from deployment outputs or your Azure environment.

AOIFMSP_AZURE_AUTH_MODE=default
AOIFMSP_AZURE_TENANT_ID=
AOIFMSP_AZURE_CLIENT_ID=
AOIFMSP_AZURE_ALLOWED_TENANTS=
AOIFMSP_AZURE_STORAGE_ACCOUNT_NAME=
AOIFMSP_AZURE_TABLES_ENDPOINT=
AOIFMSP_AZURE_BLOBS_ENDPOINT=
AOIFMSP_AZURE_QUEUES_ENDPOINT=
AOIFMSP_AZURE_KEY_VAULT_URL=
AOIFMSP_AZURE_CREATE_TABLES_IF_MISSING=true
AOIFMSP_AZURE_CREATE_CONTAINERS_IF_MISSING=true
AOIFMSP_AZURE_CREATE_QUEUES_IF_MISSING=true
